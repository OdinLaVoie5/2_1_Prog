   "source": [
    "# сделать strip   ...\n",
    "\n",
    "def is_palindrome(word):\n",
    "    word_low = word.lower()\n",
    "    drow = word_low[-1::-1]\n",
    "    return drow == word_low\n",
    "\n",
    "def is_not_palindrome(word):\n",
    "    return not is_palindrome(word)\n",
    "\n",
    "\n",
    "is_palindrome('woow woow ')\n"
   ]
  }
